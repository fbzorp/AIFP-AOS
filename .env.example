# =============================================================================
# AiFinPay AOS — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Local Docker Development)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://aifp:devpassword@localhost:5432/aifp_dev

# Production (Supabase/Neon)
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Redis (Local Docker Development)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# Production (Upstash)
# REDIS_URL=rediss://default:[password]@[host]:6379

# -----------------------------------------------------------------------------
# AI / LLM API Keys
# -----------------------------------------------------------------------------
# Primary: DeepSeek (cheapest, $0.50/M tokens)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Fallback: Anthropic Claude (higher quality, $3/M tokens)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Alternative: OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here

# -----------------------------------------------------------------------------
# AiFinPay SDK
# -----------------------------------------------------------------------------
AIFP_API_KEY=your-aifp-api-key
AIFP_BASE_URL=https://api.aifinpay.com

# -----------------------------------------------------------------------------
# Social Media APIs (for Publishing Agent)
# -----------------------------------------------------------------------------
# X (Twitter) API v2
# X_API_KEY=your-x-api-key
# X_API_SECRET=your-x-api-secret
# X_ACCESS_TOKEN=your-x-access-token
# X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# Telegram Bot
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Moltbook
# MOLTBOOK_API_KEY=your-moltbook-api-key

# -----------------------------------------------------------------------------
# Blockchain (for x402 Payment Flows)
# -----------------------------------------------------------------------------
# Solana
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_PRIVATE_KEY=base58-encoded-private-key

# EVM (Ethereum/Polygon)
# EVM_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# EVM_PRIVATE_KEY=0x-private-key

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=generate-a-random-secret-key-here-min-32-chars

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Daily spending limit for on-chain transactions (in USD)
DAILY_SPENDING_LIMIT=100.00

# Per-transaction limit (in USD)
PER_TRANSACTION_LIMIT=50.00

# Human approval threshold (in USD)
HUMAN_APPROVAL_THRESHOLD=25.00
